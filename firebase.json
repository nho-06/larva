{
    "database": {
        "rules": "database.rules.json"
    },

    "storage": {
        "rules": "storage.rules"
    },

    "hosting": {
        "public": ".",

        "ignore": [
            "firebase.json",
            "**/.*",
            "**/node_modules/**",
            "database.rules.json",
            "storage.rules"
        ],

        "headers": [
            {
                "source": "**/*.html",
                "headers": [
                    {
                        "key": "Cache-Control",
                        "value": "no-cache, no-store, must-revalidate"
                    }
                ]
            },

            {
                "source": "**/*.js",
                "headers": [
                    {
                        "key": "Cache-Control",
                        "value": "public, max-age=300"
                    }
                ]
            },

            {
                "source": "**/*.css",
                "headers": [
                    {
                        "key": "Cache-Control",
                        "value": "public, max-age=300"
                    }
                ]
            }
        ]
    }
}